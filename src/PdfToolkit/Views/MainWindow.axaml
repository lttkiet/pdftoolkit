<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:PdfToolkit.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="700"
        x:Class="PdfToolkit.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="PDF Toolkit"
        Width="1200" Height="700"
        MinWidth="600" MinHeight="500">

  <Window.DataContext>
    <vm:MainWindowViewModel />
  </Window.DataContext>

  <DockPanel>
    <!-- Toolbar -->
    <Border DockPanel.Dock="Top" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="4">
      <StackPanel Orientation="Horizontal">
        <Button Content="☰" Command="{Binding TogglePaneCommand}"
                IsVisible="{Binding IsNarrow}"
                ToolTip.Tip="Toggle sidebar menu" Margin="4,2" Width="32" />
        <Button Content="Open PDF" Command="{Binding OpenPdfCommand}" ToolTip.Tip="Open a PDF file (Ctrl+O)" Margin="4,2" />
        <Separator />
        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="8,0" />
      </StackPanel>
    </Border>

    <!-- Status Bar -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="8,4">
      <TextBlock Text="{Binding StatusText}" />
    </Border>

    <!-- SplitView: Sidebar + Content -->
    <SplitView DisplayMode="{Binding DisplayMode}"
               IsPaneOpen="{Binding IsPaneOpen}"
               OpenPaneLength="220"
               CompactPaneLength="48">
      <SplitView.Pane>
        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" Padding="0,8" ClipToBounds="True">
          <ListBox ItemsSource="{Binding Tools}"
                   SelectedIndex="{Binding SelectedToolIndex}"
                   BorderThickness="0"
                   Background="Transparent">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <StackPanel Orientation="Horizontal" Margin="4,6">
                  <TextBlock Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0" />
                  <StackPanel MaxWidth="160">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding Tooltip}" FontSize="11" Opacity="0.6" TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </Border>
      </SplitView.Pane>

      <SplitView.Content>
        <Border Padding="8" ClipToBounds="True">
          <ContentControl Content="{Binding CurrentToolView}" />
        </Border>
      </SplitView.Content>
    </SplitView>
  </DockPanel>
</Window>
