<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PdfToolkit.ViewModels.Tools"
             x:Class="PdfToolkit.Views.Tools.RotateView"
             x:DataType="vm:RotateViewModel">

  <StackPanel Margin="16" Spacing="8">
    <TextBlock Text="Rotate Pages" FontWeight="Bold" FontSize="18" />

    <TextBlock Text="Page Range:" />
    <TextBox Text="{Binding PageRange}" PlaceholderText="e.g. 1-3,5" />

    <TextBlock Text="Angle:" />
    <ComboBox ItemsSource="{Binding Angles}" SelectedItem="{Binding SelectedAngle}" />

    <Button Content="Rotate" Command="{Binding RotateCommand}" HorizontalAlignment="Left" />
  </StackPanel>
</UserControl>